{
  "name": "@snoglobe/athena",
  "version": "0.2.1",
  "description": "Terminal-native autonomous research loop runtime",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "athena": "dist/bootstrap.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:win-exe": "npm run build && node scripts/windows/build-win-exe.mjs",
    "dev": "tsx src/bootstrap.ts",
    "test": "npm run test:research && npm run test:phase5 && npm run test:phase6",
    "test:ci": "npm run test && npm run test:phase7",
    "test:research": "node --import tsx --test src/research/*.test.ts",
    "test:phase6": "node --import tsx --test src/security/policy.test.ts src/remote/connection-pool-security.test.ts src/tools/file-ops-security.test.ts",
    "test:phase7": "node --import tsx --test src/remote/connection-pool-remote-regression.test.ts src/e2e/remote-live.test.ts",
    "test:remote-live": "node --import tsx --test src/e2e/remote-live.test.ts",
    "test:phase5": "node --import tsx --test src/providers/auth/auth-manager.test.ts src/providers/provider-types.test.ts src/providers/openai/oauth.test.ts src/cli/doctor.test.ts src/remote/local-runtime.test.ts src/remote/windows-regression.test.ts src/remote/executor.test.ts src/tools/research-orchestration.test.ts src/ui/commands.test.ts src/ui/panels/research-status.test.tsx src/e2e/local-research.test.ts src/e2e/remote-research.test.ts",
    "test:release": "npm run test",
    "test:research:safety": "node --import tsx --test src/research/team-store.test.ts src/research/cli-regression.test.ts src/research/automation-safety.test.ts src/research/simulation-runner.test.ts src/store/migrations-upgrade.test.ts",
    "smoke:research": "tsx src/research/smoke.ts",
    "start": "node dist/bootstrap.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snoglobe/athena.git"
  },
  "keywords": [
    "ml",
    "research",
    "agent",
    "tui",
    "autonomous",
    "claude",
    "openai"
  ],
  "author": "snoglobe",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@hono/node-server": "^1.19.0",
    "@inkjs/ui": "^2.0.0",
    "@mozilla/readability": "^0.6.0",
    "@openai/codex-sdk": "^0.112.0",
    "@openauthjs/openauth": "^0.4.3",
    "asciichart": "^1.5.25",
    "better-sqlite3": "^11.8.1",
    "date-fns": "^4.1.0",
    "effect": "^3.19.19",
    "fullscreen-ink": "^0.1.0",
    "hono": "^4.7.0",
    "ink": "^6.0.0",
    "ink-scroll-view": "^0.3.6",
    "ink-text-input": "^6.0.0",
    "linkedom": "^0.18.12",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "nanoid": "^5.1.0",
    "react": "^19.0.0",
    "ssh2": "^1.16.0",
    "unpdf": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "@types/asciichart": "^1.5.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/marked-terminal": "^6.1.1",
    "@types/react": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
